{
  "compilerOptions": {
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true
  },
  "include": ["vite.config.ts", "electron", "src/main/**/*", "src/types/**/*"],
  "exclude": ["src/main/**/__tests__/*", "src/main/**/*.test.ts"]
}
