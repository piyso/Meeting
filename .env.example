# Environment Variables
# Copy to .env and fill in your values

# ─── AI / LLM ──────────────────────────────────────────────
# Ollama local server URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# ─── Cloud Backend ─────────────────────────────────────────
# PiyAPI cloud backend URL
PIYAPI_BASE_URL=https://api.piyapi.com/v1

# Deepgram cloud transcription API URL
DEEPGRAM_API_URL=https://api.deepgram.com/v1

# ─── Monitoring ────────────────────────────────────────────
# Sentry DSN for crash reporting (leave empty to disable)
SENTRY_DSN=

# ─── Logging ───────────────────────────────────────────────
# Log level: debug | info | warn | error
LOG_LEVEL=info

# ─── Build ─────────────────────────────────────────────────
# Node environment
NODE_ENV=development
