{
  "name": "bluearkive",
  "version": "0.3.3",
  "description": "Local-first meeting transcription application with AI-powered note expansion",
  "main": "dist-electron/main.js",
  "author": "BlueArkive",
  "license": "MIT",
  "private": true,
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "vite",
    "build": "vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "build:mac": "vite build && electron-builder --mac",
    "build:mac:universal": "vite build && electron-builder --mac --universal",
    "build:mac:arm64": "vite build && electron-builder --mac --arm64",
    "build:mac:x64": "vite build && electron-builder --mac --x64",
    "build:win": "vite build && electron-builder --win",
    "build:win:x64": "vite build && electron-builder --win --x64",
    "build:win:ia32": "vite build && electron-builder --win --ia32",
    "build:win:portable": "vite build && electron-builder --win portable",
    "build:linux": "vite build && electron-builder --linux",
    "build:linux:appimage": "vite build && electron-builder --linux AppImage",
    "build:linux:deb": "vite build && electron-builder --linux deb",
    "build:linux:rpm": "vite build && electron-builder --linux rpm",
    "build:all": "vite build && electron-builder -mwl",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-virtual": "^3.13.19",
    "@tiptap/extension-bullet-list": "^3.20.0",
    "@tiptap/extension-collaboration": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "better-sqlite3": "^12.6.2",
    "d3": "^7.9.0",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.34.3",
    "keytar": "^7.9.0",
    "lucide-react": "^0.575.0",
    "node-llama-cpp": "^3.16.2",
    "onnxruntime-node": "^1.24.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.183.2",
    "uuid": "^13.0.0",
    "y-indexeddb": "^9.0.12",
    "yjs": "^13.6.29",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.2",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electron-squirrel-startup": "^1.0.1",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^3.2.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.bluearkive.app",
    "productName": "BlueArkive",
    "copyright": "Copyright © 2024 BlueArkive",
    "npmRebuild": false,
    "afterPack": "./build/afterPack.js",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      {
        "from": "dist",
        "to": "dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "dist-electron",
        "to": "dist-electron",
        "filter": [
          "**/*"
        ]
      },
      "!src/**",
      "!electron/**",
      "!resources/**",
      "!resources/models/*.gguf",
      "!resources/models/*.bin",
      "!build/**",
      "!**/*.map",
      "!**/*.ts",
      "!**/*.tsx",
      "!**/.git/**",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/node_modules/.bin",
      "!**/node_modules/**/@types/**",
      "!**/node_modules/**/node-gyp/**",
      "!{.eslintrc*,.prettierrc*,tsconfig*,vite.config*,.gitignore,.editorconfig}",
      "!{docs,coverage,.github,.vscode}/**",
      "!**/node_modules/cmake-js/**",
      "!**/node_modules/node-llama-cpp/llama/**",
      "!**/node_modules/node-llama-cpp/templates/**",
      "!**/node_modules/node-llama-cpp/bins/**",
      "!**/node_modules/node-llama-cpp/dist/cli/**",
      "!**/node_modules/onnxruntime-node/bin/napi-v6/linux/**",
      "!**/node_modules/onnxruntime-node/bin/napi-v6/win32/**",
      "!**/node_modules/three/**",
      "!**/node_modules/@react-three/**",
      "!**/node_modules/lucide-react/**",
      "!**/node_modules/three-stdlib/**",
      "!**/node_modules/stats-gl/**",
      "!**/node_modules/hls.js/**",
      "!**/node_modules/@mediapipe/**",
      "!**/node_modules/date-fns/**",
      "!**/node_modules/react-dom/**",
      "!**/node_modules/react/**",
      "!**/node_modules/@tiptap/**",
      "!**/node_modules/prosemirror-*/**",
      "!**/node_modules/recharts/**",
      "!**/node_modules/d3-*/**",
      "!**/node_modules/lodash/**",
      "!**/node_modules/yjs/**",
      "!**/node_modules/typescript/**",
      "!**/release/**",
      "!**/landing-web/**",
      "!**/billing-web/**",
      "!**/*.md",
      "!.env",
      "!.env.*",
      "!.kiro/**",
      "!.eslintignore",
      "!.prettierignore",
      "!0.01"
    ],
    "extraResources": [
      {
        "from": "resources/models",
        "to": "models",
        "filter": [
          "silero_vad.onnx",
          "all-MiniLM-L6-v2*"
        ]
      }
    ],
    "publish": {
      "provider": "generic",
      "url": "https://dl.bluearkive.com"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "type": "distribution",
      "minimumSystemVersion": "11.0",
      "darkModeSupport": true,
      "files": [
        "!**/node_modules/onnxruntime-node/bin/napi-v6/win32/**"
      ],
      "extendInfo": {
        "NSMicrophoneUsageDescription": "BlueArkive needs microphone access to record meeting audio for transcription.",
        "NSScreenCaptureDescription": "BlueArkive needs screen recording permission to capture system audio during meetings.",
        "LSMinimumSystemVersion": "11.0"
      }
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      },
      "backgroundColor": "#ffffff",
      "icon": "build/icon.icns",
      "iconSize": 128,
      "title": "Install ${productName}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "publisherName": "BlueArkive",
      "verifyUpdateCodeSignature": false,
      "requestedExecutionLevel": "asInvoker",
      "files": [
        "!**/node_modules/onnxruntime-node/bin/napi-v6/darwin/**",
        "!**/node_modules/node-llama-cpp/prebuilds/mac-*/**",
        "!**/node_modules/node-llama-cpp/prebuilds/linux-*/**"
      ],
      "fileAssociations": [
        {
          "ext": "pnotes",
          "name": "BlueArkive Meeting",
          "description": "BlueArkive Meeting File",
          "icon": "build/file-icon.ico",
          "role": "Editor"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "${productName}",
      "perMachine": false,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "include": "build/installer.nsh",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    },
    "appImage": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icons",
      "category": "Office;AudioVideo;Recorder",
      "synopsis": "Local-first meeting transcription with AI-powered notes",
      "description": "BlueArkive is a local-first meeting transcription application that provides real-time audio transcription, AI-powered note expansion, and intelligent meeting analysis.",
      "desktop": {
        "Name": "BlueArkive",
        "Comment": "Meeting transcription and AI notes",
        "Keywords": "meeting;transcription;notes;ai;productivity",
        "StartupWMClass": "bluearkive"
      },
      "fileAssociations": [
        {
          "ext": "pnotes",
          "name": "BlueArkive Meeting",
          "description": "BlueArkive Meeting File",
          "mimeType": "application/x-bluearkive"
        }
      ]
    },
    "deb": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libuuid1"
      ],
      "priority": "optional",
      "afterInstall": "build/linux-after-install.sh"
    },
    "rpm": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "depends": [
        "gtk3",
        "libnotify",
        "nss",
        "libXScrnSaver",
        "libXtst",
        "xdg-utils",
        "at-spi2-core",
        "libuuid"
      ],
      "afterInstall": "build/linux-after-install.sh"
    },
    "protocols": [
      {
        "name": "bluearkive",
        "schemes": [
          "bluearkive"
        ],
        "role": "Editor"
      }
    ],
    "compression": "maximum",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "**/node-llama-cpp/**",
      "**/onnxruntime-node/**"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/piyso/piynoteskiro.git"
  },
  "homepage": "https://bluearkive.com",
  "bugs": {
    "url": "https://github.com/piyso/piynoteskiro/issues"
  }
}
