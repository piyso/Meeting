# BlueArkive Environment Variables
# Copy to .env and fill in your values

# ─── Mock Data Mode ─────────────────────────────────────────
# Set to 'true' for offline UI development (no Supabase needed)
# Set to 'false' for real backend connectivity
USE_MOCK_DATA=false

# ─── Cloud Backend (Supabase — REQUIRED for cloud features) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here

# ─── PiyAPI Cloud Backend ────────────────────────────────────
PIYAPI_BASE_URL=https://api.piyapi.cloud

# ─── Deepgram Cloud Transcription ───────────────────────────
DEEPGRAM_API_URL=https://api.deepgram.com/v1

# ─── BlueArkive Billing ─────────────────────────────────────
# Leave empty in dev (uses local billing-web at localhost:5173)
PIYNOTES_BILLING_URL=

# ─── Monitoring ─────────────────────────────────────────────
SENTRY_DSN=

# ─── Logging ────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Build ──────────────────────────────────────────────────
NODE_ENV=development

# ─── Recording (optional) ──────────────────────────────────
# MAX_RECORDING_DURATION_MS=0
# AUTO_SAVE_INTERVAL_MS=30000
# WAL_CHECKPOINT_INTERVAL_MS=300000
# SESSION_TIMEOUT_MS=0

# ═══════════════════════════════════════════════════════════════
# SUPABASE EDGE FUNCTION SECRETS (set via `supabase secrets set`)
# ═══════════════════════════════════════════════════════════════
# RAZORPAY_WEBHOOK_SECRET=whsec_...
# LEMON_WEBHOOK_SECRET=whsec_...
# WEBHOOK_SECRET=your_on_signup_webhook_secret
# SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role-key
